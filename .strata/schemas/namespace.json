{
  "$defs": {
    "CommonLifecycleModel": {
      "additionalProperties": {
        "$ref": "#/$defs/CommonLifecyclePhaseModel"
      },
      "default": {},
      "description": "Lifecycle phases for common models.\nMaps phase names to phase configurations.\nPhase names follow pattern: {command}_{action}_{suffix}\nExamples: config_clear, config_fetch, deploy_plan_before, deploy_apply_after",
      "title": "CommonLifecycleModel",
      "type": "object"
    },
    "CommonLifecyclePhaseModel": {
      "description": "Model for common lifecycle phase with script validation.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional description for documentation purposes",
          "title": "Description"
        },
        "scripts": {
          "anyOf": [
            {
              "items": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "$ref": "#/$defs/ScriptPathModel"
                  }
                ]
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Scripts"
        }
      },
      "title": "CommonLifecyclePhaseModel",
      "type": "object"
    },
    "NamespaceMetaModel": {
      "description": "Model for namespace metadata (name, annotations, labels, tags).",
      "properties": {
        "name": {
          "description": "Unique namespace name",
          "maxLength": 64,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "title": "Name",
          "type": "string"
        },
        "annotations": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional annotations (key-value pairs for documentation)",
          "title": "Annotations"
        },
        "labels": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional labels (key-value pairs for classification/filtering)",
          "title": "Labels"
        },
        "tags": {
          "anyOf": [
            {
              "items": {},
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional list of tags",
          "title": "Tags"
        }
      },
      "required": [
        "name"
      ],
      "title": "NamespaceMetaModel",
      "type": "object"
    },
    "NamespaceModuleModel": {
      "description": "Model for a namespace module (name, description, properties, lifecycle, labels, tags).",
      "properties": {
        "name": {
          "description": "Unique module name within the namespace",
          "maxLength": 64,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "title": "Name",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional description of what this module provides",
          "title": "Description"
        },
        "file": {
          "description": "File reference for the module configuration or script",
          "title": "File",
          "type": "string"
        }
      },
      "required": [
        "name",
        "file"
      ],
      "title": "NamespaceModuleModel",
      "type": "object"
    },
    "NamespaceReferenceModel": {
      "description": "References to variables, secrets, and features required by this namespace.\n\nLists the keys that must be defined in the environment configuration.\nActual values and store backends are defined at environment/workspace level.",
      "properties": {
        "variables": {
          "anyOf": [
            {
              "items": {
                "minLength": 1,
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "List of variable keys this namespace requires from environment",
          "title": "Variables"
        },
        "secrets": {
          "anyOf": [
            {
              "items": {
                "minLength": 1,
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "List of secret keys this namespace requires from environment",
          "title": "Secrets"
        },
        "features": {
          "anyOf": [
            {
              "items": {
                "minLength": 1,
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "List of feature flag keys this namespace requires from environment",
          "title": "Features"
        }
      },
      "title": "NamespaceReferenceModel",
      "type": "object"
    },
    "NamespaceSpecModel": {
      "description": "Model for namespace spec (lifecycle, modules, validation).",
      "properties": {
        "lifecycle": {
          "anyOf": [
            {
              "$ref": "#/$defs/CommonLifecycleModel"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Namespace lifecycle phases"
        },
        "modules": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/NamespaceModuleModel"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "List of modules in the namespace",
          "title": "Modules"
        },
        "references": {
          "anyOf": [
            {
              "$ref": "#/$defs/NamespaceReferenceModel"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Namespace references for variable and secret injection"
        }
      },
      "title": "NamespaceSpecModel",
      "type": "object"
    },
    "PlatformKind": {
      "description": "Enumeration of supported platform kinds.",
      "enum": [
        "configuration",
        "deployment",
        "environment",
        "firewall",
        "module",
        "namespace",
        "platform_model",
        "provider",
        "resource",
        "workspace"
      ],
      "title": "PlatformKind",
      "type": "string"
    },
    "PlatformVersion": {
      "description": "Enumeration of supported platform versions.",
      "enum": [
        "platform.huybrechts.xyz/v1"
      ],
      "title": "PlatformVersion",
      "type": "string"
    },
    "ScriptPathModel": {
      "description": "Individual script with scope and execution metadata.",
      "properties": {
        "file": {
          "description": "Path to script file",
          "title": "File",
          "type": "string"
        },
        "scope": {
          "$ref": "#/$defs/PlatformKind",
          "description": "Execution scope - determines how many times script runs (deployment, environment, workspace, provider, resource, module, namespace)"
        },
        "priority": {
          "default": 100,
          "description": "Execution order within scope (lower runs first)",
          "maximum": 9999,
          "minimum": 0,
          "title": "Priority",
          "type": "integer"
        },
        "target": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional target filter (e.g., 'vm-*', 'azure-*', 'production')",
          "title": "Target"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional description for documentation purposes",
          "title": "Description"
        }
      },
      "required": [
        "file",
        "scope"
      ],
      "title": "ScriptPathModel",
      "type": "object"
    }
  },
  "description": "Top-level model for a namespace resource.",
  "properties": {
    "apiVersion": {
      "$ref": "#/$defs/PlatformVersion",
      "default": "platform.huybrechts.xyz/v1",
      "description": "API version for namespace configuration"
    },
    "kind": {
      "$ref": "#/$defs/PlatformKind",
      "default": "namespace",
      "description": "Resource kind (always 'Namespace')"
    },
    "meta": {
      "$ref": "#/$defs/NamespaceMetaModel",
      "description": "Namespace metadata (name, annotations, labels, tags)"
    },
    "spec": {
      "$ref": "#/$defs/NamespaceSpecModel",
      "description": "Namespace specification (lifecycle, modules, variables, secrets)"
    }
  },
  "required": [
    "meta",
    "spec"
  ],
  "title": "NamespaceModel",
  "type": "object"
}